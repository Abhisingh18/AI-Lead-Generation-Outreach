# ============================================================
#  AI Lead Generation & Outreach Platform — environment config
#  Copy this file to ".env" and fill in real values.
# ============================================================

# ---------- Database ----------
# Local Postgres example. For Supabase use the connection string from the dashboard.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/leadgen

# ---------- LLM ----------
# Provider: "zhipu" (GLM 5.2 native) or "openrouter"
LLM_PROVIDER=zhipu

# GLM 5.2 (Zhipu AI) — https://open.bigmodel.cn  (free/cheap, default)
ZHIPU_API_KEY=your_zhipu_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.5-flash

# OpenRouter — https://openrouter.ai  (fallback / scale)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat

# ---------- Scraper ----------
SCRAPER_HEADLESS=true
SCRAPER_MAX_RESULTS=20
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0

# ---------- WhatsApp sender (Playwright + WhatsApp Web) ----------
WHATSAPP_SENDER_NUMBER=
WHATSAPP_COUNTRY_CODE=91
WHATSAPP_SESSION_DIR=.wa_session
WHATSAPP_HEADLESS=false
WHATSAPP_DRY_RUN=true
WHATSAPP_DAILY_LIMIT=30
WHATSAPP_DELAY_MIN=8.0
WHATSAPP_DELAY_MAX=20.0

# ---------- App ----------
APP_ENV=development
LOG_LEVEL=INFO
